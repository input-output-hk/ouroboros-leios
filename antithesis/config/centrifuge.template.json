{
  "initial_inputs": {
    "type": "genesis_utxo_keys",
    "params": {
      "network_magic": 164,
      "signing_keys_file": "funds.json"
    }
  },
  "builder": {
    "type": "value",
    "params": {
      "inputs_per_tx": 1,
      "outputs_per_tx": 1,
      "fee": 1000000,
      "optimistic_recycle": false
    }
  },
  "rate_limit": {
    "type": "token_bucket",
    "scope": "shared",
    "params": { "tps": ${TPS} }
  },
  "workloads": {
    "synthetic-chain": {
        "targets": {
            "pool1": {"addr": "${IP_POOL1}", "port": ${PORT_POOL1}}
        }
    }
  },
  "nodeConfig": "config.yaml",
  "protocolParametersFile": "pp.json"
}
