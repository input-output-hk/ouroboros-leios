          "direction": "backward",
          "editorMode": "code",
          "expr": "{service=\"call-trace\", event=\"End\", instance=~\"$instance\", name=~\"$name\"} \n  | json\n  | regexp `(?P<parent_prefix>.*)\\.([0-9]+)$`\n  # Span fields\n  | label_format spanID=`{{ .id }}`\n  | label_format operationName=`{{ .name }}`\n  | label_format duration_sec=`{{ .duration }}`\n  | label_format serviceName=`{{ .thread }}`\n  | label_format host=`{{ .process }}`\n  | label_format traceID=`{{ .local_id }}`\n  | label_format parentSpanID=`{{ .parent_prefix }}`\n  # Extra fields TODO: Figure out how to add this to span attributes\n  #| label_format allocations=`{{ .allocations }}`\n  #| label_format argument=`{{ .argument }}`\n  #| label_format result=`{{ .result }}`\n    \n  | keep traceID, spanID, parentSpanID, operationName, duration_sec, serviceName, host",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Traces",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "delimiter": ",",
            "format": "json",
            "source": "labels"
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "duration",
            "binary": {
              "left": {
                "matcher": {
                  "id": "byName",
                  "options": "duration_sec"
                }
              },
              "operator": "*",
              "right": {
                "fixed": "1000"
              }
            },
            "mode": "binary",
            "reduce": {
              "reducer": "sum"
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "startTime",
            "binary": {
              "left": {
                "matcher": {
                  "id": "byName",
                  "options": "Time"
                }
              },
              "operator": "-",
              "right": {
                "matcher": {
                  "id": "byName",
                  "options": "duration"
                }
              }
            },
            "mode": "binary",
            "reduce": {
              "reducer": "sum"
            }
          }
        }
      ],
